      "data_classification": "public",
      "audit_meta_allowlist": [],
      "description": "List available models"
    },
    {
      "id": "mcp.tools.call",
      "type": "http",
      "http_match": {
        "method": "POST",
        "path_template": "/v1/mcp/servers/{server_id}/tools/{tool_name}:call"
      },
      "required_scopes": ["mcp.invoke"],
      "attestation_required": true,
      "audit_action": "mcp.tools.execute",
