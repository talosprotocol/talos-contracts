{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://talos.network/schemas/a2a/v1/task_status.schema.json",
  "type": "object",
  "required": ["state", "timestamp"],
  "properties": {
    "state": {
      "type": "string",
      "enum": [
        "TASK_STATE_SUBMITTED",
        "TASK_STATE_WORKING",
        "TASK_STATE_COMPLETED",
        "TASK_STATE_FAILED",
        "TASK_STATE_CANCELED",
        "TASK_STATE_INPUT_REQUIRED",
        "TASK_STATE_REJECTED",
        "TASK_STATE_AUTH_REQUIRED"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z|[+-]\\d{2}:\\d{2}$"
    },
    "message": { "$ref": "message.schema.json" }
  },
  "additionalProperties": false
}
