{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://talos.network/schemas/a2a/v1/methods/send_streaming_message.request.schema.json",
  "type": "object",
  "required": ["jsonrpc", "method", "params", "id"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "method": { "const": "SendStreamingMessage" },
    "id": { "type": ["string", "integer"] },
    "params": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "$ref": "../message.schema.json" },
        "configuration": {
          "type": "object",
          "properties": {
            "acceptedOutputModes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "historyLength": { "type": "integer", "minimum": 0 },
            "returnImmediately": { "type": "boolean" },
            "taskPushNotificationConfig": {
              "$ref": "../task_push_notification_config.schema.json"
            },
            "pushNotificationConfig": {
              "$ref": "../task_push_notification_config.schema.json"
            }
          },
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
