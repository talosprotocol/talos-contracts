{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://talos.network/schemas/a2a/v1/methods/send_message.response.schema.json",
  "type": "object",
  "required": ["jsonrpc", "id", "result"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "id": { "type": ["string", "integer", "null"] },
    "result": {
      "type": "object",
      "required": ["task"],
      "properties": {
        "task": { "$ref": "../task.schema.json" },
        "message": { "$ref": "../message.schema.json" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
